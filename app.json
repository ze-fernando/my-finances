{
  "expo": {
    "name": "Minhas Finanças",
    "slug": "my-finances",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#535353"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ze-fernando.myfinances"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-normal.png",
        "monochromeImage": "./assets/icon-normal.png",
        "backgroundColor": "#535353"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ze_fernando.myfinances"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "98cdf82f-b94a-4a46-8e34-672928b6adc3"
      }
    }
  }
}
